# ===== TBox Configuration =====
TBOX_BASE_URL=https://api.tbox.cn
TBOX_APP_ID=your_app_id_here
TBOX_TOKEN=your_token_here

# ===== Adapter Configuration =====
# The model ID exposed to OpenAI-compatible clients
ADAPTER_MODEL_ID=tbox-codex

# Default userId when not provided by caller
ADAPTER_DEFAULT_USER=default-user

# Request timeout in seconds for TBox API calls
TBOX_TIMEOUT=60

# ===== Retry Configuration (non-streaming requests only) =====
# Total number of attempts (1 = no retry)
TBOX_RETRY_MAX_ATTEMPTS=3
# Initial back-off delay in seconds; doubles each attempt with full jitter
TBOX_RETRY_BACKOFF_BASE=0.5
# Maximum back-off delay cap in seconds
TBOX_RETRY_BACKOFF_MAX=10.0

# ===== Circuit Breaker Configuration =====
# Consecutive failures before the circuit opens (fast-fail mode)
TBOX_CB_FAILURE_THRESHOLD=5
# Seconds the circuit stays open before probing again (half-open)
TBOX_CB_RECOVERY_TIMEOUT=30.0
# Consecutive successes in half-open mode needed to close the circuit
TBOX_CB_HALF_OPEN_PROBES=2

# ===== Server Configuration =====
HOST=0.0.0.0
PORT=2233

# Set to "true" to enable debug logging
DEBUG=false

# ===== Metrics Configuration =====
# Set to "true" to expose Prometheus /metrics endpoint (enabled by default)
METRICS_ENABLED=true
